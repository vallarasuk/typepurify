{
  "name": "typepurify",
  "version": "1.4.2",
  "description": "Deep-clean any API response while preserving precisely inferred recursive types—no schemas, no boilerplate.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "format": "prettier --write 'src/**/*.{js,ts,json,md}'",
    "format:check": "prettier --check 'src/**/*.{js,ts,json,md}'",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "release:patch": "npm version patch -m \"chore(release): %s\" && git push --follow-tags",
    "release:minor": "npm version minor -m \"chore(release): %s\" && git push --follow-tags",
    "release:major": "npm version major -m \"chore(release): %s\" && git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vallarasuk/typepurify.git"
  },
  "bugs": {
    "url": "https://github.com/vallarasuk/typepurify/issues"
  },
  "homepage": "https://github.com/vallarasuk/typepurify#readme",
  "keywords": [
    "typescript",
    "type-inference",
    "clean-object",
    "remove-null",
    "remove-undefined",
    "payload-normalization",
    "zero-schema",
    "bff-cleaner"
  ],
  "author": "Vallarasu Kanthasamy",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
